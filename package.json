{
  "name": "ibm-compass",
  "version": "1.0.0",
  "description": "Agentic AI for Performance Intelligence — transforms KPI reporting into an AI-powered intelligence and recommendation engine.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "eval":  "node -e \"fetch('http://localhost:3000/api/eval',{method:'POST'}).then(r=>r.json()).then(d=>{console.log(JSON.stringify(d.summary,null,2));if(!d.summary.aboveThreshold){console.error('EVAL FAILED: pass rate',d.summary.passRate+'% <',d.summary.threshold+'% threshold');process.exit(1);}})\"",
    "test":  "npm run eval"
  },
  "keywords": [
    "ai",
    "agentic",
    "kpi",
    "ibm",
    "watsonx",
    "performance-intelligence",
    "product-management"
  ],
  "author": "Puru Nayak <github.com/puru-nayak-labs>",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
